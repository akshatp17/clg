P10 = [3, 5, 2, 7, 4, 10, 1, 9, 8, 6]
P8  = [6, 3, 7, 4, 8, 5, 10, 9]

def permute(key, table):
    return ''.join([key[i-1] for i in table])

def left_shift(bits, shifts):
    return bits[shifts:] + bits[:shifts]

def generate_keys(key10):
    print("Original Key:", key10)

    key = permute(key10, P10)
    print("After P10:", key)

    left = key[:5]
    right = key[5:]
    print("Left:", left)
    print("Right:", right)

    left = left_shift(left, 1)
    right = left_shift(right, 1)
    print("After LS-1:", left + right)

    key1 = permute(left + right, P8)
    print("Key1:", key1)

    left = left_shift(left, 2)
    right = left_shift(right, 2)
    print("After LS-2:", left + right)

    key2 = permute(left + right, P8)
    print("Key2:", key2)

    return key1, key2

key_input = input("Enter 10-bit key: ")
k1, k2 = generate_keys(key_input)

print("Final Key1:", k1)
print("Final Key2:", k2)

