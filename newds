import numpy as np
def text_to_numbers(text):	
    return [ord(c) - 65 for c in text]
# Convert numbers to text
def numbers_to_text(numbers):
    return ''.join(chr(n + 65) for n in numbers)
# Find modular inverse of determinant
def mod_inverse(a, m):
    for i in range(1, m):
        if (a * i) % m == 1:
            return i
    return None
# Find inverse of 3x3 matrix modulo 26
def matrix_inverse_mod26(matrix):
    det = int(round(np.linalg.det(matrix)))
    det_mod = det % 26
    det_inv = mod_inverse(det_mod, 26)
    if det_inv is None:
        raise ValueError("Matrix is not invertible modulo 26")
    adjugate = np.round(det * np.linalg.inv(matrix)).astype(int)
    inv_matrix = (det_inv * adjugate) % 26
    return inv_matrix
# Encrypt
def encrypt(plaintext, key):
    plaintext = plaintext.upper().replace(" ", "")
    while len(plaintext) % 3 != 0:
        plaintext += 'X'
    nums = text_to_numbers(plaintext)
    cipher = []
    for i in range(0, len(nums), 3):
        block = np.array(nums[i:i+3])
        encrypted = key.dot(block) % 26
        cipher.extend(encrypted)
    return numbers_to_text(cipher)
# Decrypt
def decrypt(ciphertext, key):
    inv_key = matrix_inverse_mod26(key)
    nums = text_to_numbers(ciphertext)
    plain = []
    for i in range(0, len(nums), 3):

        block = np.array(nums[i:i+3])
        decrypted = inv_key.dot(block) % 26
        plain.extend(decrypted)
    return numbers_to_text(plain)

