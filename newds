# Publicly shared values
p = 23   # Prime number
g = 5    # Primitive root

# Private keys (chosen by users)
a = 6    # Private key of User A
b = 15   # Private key of User B

# Compute public keys
A = pow(g, a, p)   # A = g^a mod p
B = pow(g, b, p)   # B = g^b mod p

print("Public key of A:", A)
print("Public key of B:", B)

# Compute shared secret keys
secret_A = pow(B, a, p)   # (g^b)^a mod p
secret_B = pow(A, b, p)   # (g^a)^b mod p

print("Secret key computed by A:", secret_A)
print("Secret key computed by B:", secret_B)
