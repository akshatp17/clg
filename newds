def rail_fence_encrypt(text, depth=2):
    text = text.replace(" ", "").lower()

    rails = ['' for _ in range(depth)]
    row = 0
    direction = 1

    for char in text:
        rails[row] += char
        row += direction
        if row == 0 or row == depth - 1:
            direction *= -1

    return ''.join(rails).upper()

def rail_fence_decrypt(cipher, depth=2):
    n = len(cipher)

    pattern = [['\n' for _ in range(n)] for _ in range(depth)]
    row, direction = 0, 1

    for col in range(n):
        pattern[row][col] = '*'
        row += direction
        if row == 0 or row == depth - 1:
            direction *= -1

    index = 0
    for i in range(depth):
        for j in range(n):
            if pattern[i][j] == '*' and index < n:
                pattern[i][j] = cipher[index]
                index += 1

    result = ""
    row, direction = 0, 1

    for col in range(n):
        result += pattern[row][col]
        row += direction
        if row == 0 or row == depth - 1:
            direction *= -1

    return result.upper()

